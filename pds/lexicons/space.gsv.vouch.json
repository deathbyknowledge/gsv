{
  "lexicon": 1,
  "id": "space.gsv.vouch",
  "description": "Public GSV endorsement record.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["$type", "createdAt", "subject"],
        "properties": {
          "$type": {
            "type": "string",
            "const": "space.gsv.vouch"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          },
          "subject": {
            "type": "ref",
            "ref": "#recordRef"
          },
          "note": {
            "type": "string",
            "maxGraphemes": 300,
            "maxLength": 1200
          },
          "tags": {
            "type": "array",
            "maxLength": 20,
            "items": {
              "type": "string",
              "maxGraphemes": 64,
              "maxLength": 256
            }
          }
        }
      }
    },
    "recordRef": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "uri": {
          "type": "string",
          "format": "at-uri",
          "maxLength": 2048
        },
        "cid": {
          "type": "string",
          "format": "cid",
          "maxLength": 256
        }
      }
    }
  }
}
