{
  "lexicon": 1,
  "id": "space.gsv.contact",
  "description": "Public GSV contact graph edge record.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["$type", "createdAt", "subject"],
        "properties": {
          "$type": {
            "type": "string",
            "const": "space.gsv.contact"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          },
          "subject": {
            "type": "ref",
            "ref": "#subject"
          },
          "label": {
            "type": "string",
            "maxGraphemes": 64,
            "maxLength": 256
          },
          "tags": {
            "type": "array",
            "maxLength": 20,
            "items": {
              "type": "string",
              "maxGraphemes": 64,
              "maxLength": 256
            }
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "required": ["did"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did",
          "maxLength": 2048
        },
        "handle": {
          "type": "string",
          "format": "handle",
          "maxLength": 253
        },
        "uri": {
          "type": "string",
          "format": "at-uri",
          "maxLength": 2048
        }
      }
    }
  }
}
