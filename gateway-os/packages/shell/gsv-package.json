{
  "name": "shell",
  "description": "Interactive command shell for nodes.",
  "version": "0.1.0",
  "runtime": "web-ui",
  "entrypoints": [
    {
      "name": "shell",
      "kind": "ui",
      "route": "/apps/shell",
      "icon": { "kind": "builtin", "id": "shell" },
      "syscalls": ["shell.exec", "sys.device.list"],
      "windowDefaults": { "width": 980, "height": 640, "minWidth": 700, "minHeight": 420 },
      "module": "ui/worker.ts",
      "description": "Interactive command shell for nodes."
    }
  ],
  "capabilities": {
    "bindings": [
      {
        "binding": "KERNEL",
        "kind": "kernel",
        "interfaceName": "gsv.kernel.app.v1",
        "required": true,
        "description": "Package-scoped req/res binding for kernel-native syscalls."
      }
    ],
    "egress": { "mode": "none" }
  },
  "artifact": {
    "mainModule": "ui/worker.ts",
    "compatibilityDate": "2026-01-28"
  }
}
