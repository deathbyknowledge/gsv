{
  "manifest_version": 3,
  "name": "GSV Browser Target",
  "description": "Expose this browser profile as a Unix-looking GSV target.",
  "version": "0.4.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/gsv-16.png",
    "32": "icons/gsv-32.png",
    "48": "icons/gsv-48.png",
    "64": "icons/gsv-64.png",
    "96": "icons/gsv-96.png",
    "128": "icons/gsv-128.png",
    "256": "icons/gsv-256.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "clipboardRead",
    "clipboardWrite",
    "cookies",
    "debugger",
    "downloads",
    "downloads.open",
    "history",
    "notifications",
    "offscreen",
    "sidePanel",
    "scripting",
    "storage",
    "tabCapture",
    "tabs",
    "unlimitedStorage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; img-src 'self' blob: data:; media-src 'self' blob: data:; frame-src 'self' blob: data:;"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/gsv-16.png",
      "24": "icons/gsv-24.png",
      "32": "icons/gsv-32.png",
      "48": "icons/gsv-48.png",
      "64": "icons/gsv-64.png"
    },
    "default_title": "GSV Browser Target",
    "default_popup": "popup.html"
  }
}
