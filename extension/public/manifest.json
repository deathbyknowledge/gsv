{
  "manifest_version": 3,
  "name": "GSV Browser Target",
  "description": "Expose this browser profile as a Unix-looking GSV target.",
  "version": "0.3.1",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "clipboardRead",
    "clipboardWrite",
    "cookies",
    "debugger",
    "downloads",
    "downloads.open",
    "history",
    "notifications",
    "offscreen",
    "sidePanel",
    "scripting",
    "storage",
    "tabCapture",
    "tabs",
    "unlimitedStorage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; img-src 'self' blob: data:; media-src 'self' blob: data:; frame-src 'self' blob: data:;"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "GSV Browser Target",
    "default_popup": "popup.html"
  }
}
